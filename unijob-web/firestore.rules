rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read: if true; // Public read for job listings
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['title', 'description', 'category', 'postedBy'])
        && request.resource.data.postedBy == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Owner can update any field
        resource.data.postedBy == request.auth.uid ||
        // Non-owners can only modify applicants (to apply)
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicants']) &&
          request.resource.data.applicants.size() == resource.data.applicants.size() + 1
        )
      );
      allow delete: if isAuthenticated() && resource.data.postedBy == request.auth.uid;
    }

    // Applications collection
    match /applications/{applicationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.applicantId == request.auth.uid;
      // Only job poster can update status (accept/reject)
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if false;
    }

    // Ratings collection
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.fromUserId != request.resource.data.toUserId
        && request.resource.data.score >= 1
        && request.resource.data.score <= 5;
      allow update: if false;
      allow delete: if false;
    }

    // Job Completions collection
    match /jobCompletions/{completionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Only allow updating confirmation fields
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['workerConfirmed', 'posterConfirmed', 'completedAt', 'status']);
      allow delete: if false;
    }

    // Work History collection
    match /workHistory/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
  }
}
